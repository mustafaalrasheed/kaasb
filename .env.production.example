# =============================================================================
# Kaasb Platform — Production Environment Template
# =============================================================================
# USAGE:
#   cp .env.production.example .env.production
#   nano .env.production          # Fill in every CHANGE_ME value
#   chmod 600 .env.production     # Restrict file permissions
#
# SECRET GENERATION COMMANDS:
#   SECRET_KEY:     openssl rand -hex 32
#   REDIS_PASSWORD: openssl rand -hex 24
#   DB_PASSWORD:    openssl rand -base64 24 | tr -dc 'a-zA-Z0-9' | head -c 32
# =============================================================================

# ---------------------------------------------------------------------------
# Domain & Deployment
# ---------------------------------------------------------------------------
DOMAIN=kaasb.com
GITHUB_REPO=mustafaalrasheed/kaasb
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Application Identity
# ---------------------------------------------------------------------------
APP_NAME=Kaasb
APP_VERSION=1.0.0

# ---------------------------------------------------------------------------
# PostgreSQL Database
# Generate: openssl rand -base64 24 | tr -dc 'a-zA-Z0-9' | head -c 32
# ---------------------------------------------------------------------------
DB_USER=kaasb_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=kaasb_db

# ---------------------------------------------------------------------------
# Redis — must match --requirepass in docker-compose.prod.yml
# Generate: openssl rand -hex 24
# ---------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ---------------------------------------------------------------------------
# JWT Secret Key — 64 hex characters
# Generate: openssl rand -hex 32
# ROTATION: Rotating this invalidates ALL active sessions immediately.
# ---------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_64_HEX_CHARS

# ---------------------------------------------------------------------------
# Gunicorn Workers (formula: 2 * CPU_CORES + 1)
# CX22 = 2 vCPU → 5 workers | CX32 = 4 vCPU → 9 workers
# ---------------------------------------------------------------------------
WEB_CONCURRENCY=5

# ---------------------------------------------------------------------------
# Qi Card Payment Gateway — Iraqi primary payment
# Get credentials: https://qi.iq → Merchant Portal
# ROTATION: Rotate QI_CARD_SECRET_KEY every 6 months
# ---------------------------------------------------------------------------
QI_CARD_API_KEY=              # Authorization header value (raw API key from merchant portal)
QI_CARD_BASE_URL=https://api.pay.qi.iq/api/v0/transactions/business/token
QI_CARD_SANDBOX_URL=https://api.uat.pay.qi.iq/api/v0/transactions/business/token
QI_CARD_SANDBOX=true          # true = UAT, false = production
QI_CARD_CURRENCY=IQD

# Qi Card v1 3DS (Phase 4 — fill in once Qi Card provisions the merchant on v1)
QI_CARD_USE_V1=false                                # Flip to true ONLY when all 4 v1 vars below are populated AND a UAT smoke test passed
QI_CARD_V1_HOST=https://3ds-api.qi.iq
QI_CARD_V1_SANDBOX_HOST=https://uat-sandbox-3ds-api.qi.iq
QI_CARD_V1_USER=                                    # Basic-auth username from Qi Card merchant onboarding
QI_CARD_V1_PASS=                                    # Basic-auth password from Qi Card merchant onboarding
QI_CARD_V1_TERMINAL_ID=                             # X-Terminal-Id header value

# ---------------------------------------------------------------------------
# Zain Cash Payment Gateway — Iraqi mobile-money (parallel to Qi Card)
# Provided by Zain Cash merchant onboarding email (subject usually "zaincash live credentials").
# Sandbox URL: https://test.zaincash.iq, prod URL: https://api.zaincash.iq.
# Set MERCHANT_ID, MERCHANT_SECRET, and MSISDN together — partial config refuses to boot.
# Auth is HS256 JWT signed with MERCHANT_SECRET (no separate API key).
# ---------------------------------------------------------------------------
ZAIN_CASH_PRODUCTION=false       # true = api.zaincash.iq, false = test.zaincash.iq
ZAIN_CASH_MERCHANT_ID=           # Merchant ID from onboarding email
ZAIN_CASH_MERCHANT_SECRET=       # Bearer secret used to sign init JWT and verify callback JWT
ZAIN_CASH_MSISDN=                # Merchant phone, e.g. 9647827124591 (no leading +)
ZAIN_CASH_LANG=ar                # ar | en — passed to Zain Cash's hosted page
ZAIN_CASH_SERVICE_TYPE=Kaasb     # Free-form label shown on Zain Cash's hosted page

# ---------------------------------------------------------------------------
# Email — Resend (https://resend.com — free tier 3k emails/month)
# Get your API key at: https://resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Kaasb <noreply@kaasb.com>
EMAIL_FROM_NAME=Kaasb
FRONTEND_URL=https://kaasb.com

# ---------------------------------------------------------------------------
# Monitoring & Observability
# Sentry: https://sentry.io → Settings → Client Keys → DSN
# HEALTH_BEARER_TOKEN: openssl rand -hex 20 (protects /api/v1/health/detailed)
# ---------------------------------------------------------------------------
SENTRY_DSN=
HEALTH_BEARER_TOKEN=CHANGE_ME_HEALTH_TOKEN

# ---------------------------------------------------------------------------
# Grafana (monitoring dashboard)
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ---------------------------------------------------------------------------
# Alertmanager — Discord webhook (critical/high) + Gmail SMTP (medium/low)
# Discord webhook: channel → Integrations → Webhooks → New Webhook → Copy URL
# Gmail app password: https://myaccount.google.com/apppasswords (2FA required)
# ---------------------------------------------------------------------------
ALERTMANAGER_DISCORD_WEBHOOK_URL=
ALERTMANAGER_SMTP_FROM=
ALERTMANAGER_SMTP_TO=
ALERTMANAGER_SMTP_AUTH_USERNAME=
ALERTMANAGER_SMTP_AUTH_PASSWORD=

# ---------------------------------------------------------------------------
# Google OAuth (Social Login)
# From: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized JS Origins: https://kaasb.com
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID

# ---------------------------------------------------------------------------
# Facebook Login (Social Login — optional)
# From: https://developers.facebook.com → My Apps → App Settings
# ---------------------------------------------------------------------------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ---------------------------------------------------------------------------
# Twilio (SMS OTP — production)
# From: https://console.twilio.com
# Leave empty to use email-based OTP delivery instead.
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=CHANGE_ME_TWILIO_SID
TWILIO_AUTH_TOKEN=CHANGE_ME_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ---------------------------------------------------------------------------
# File Uploads
# ---------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10
