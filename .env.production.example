# ============================================================
# Kaasb Platform — Production Environment
# ============================================================
# Copy this file to .env.production and fill in all values.
#
#   cp .env.production.example .env.production
#
# IMPORTANT: Never commit .env.production to version control.
# ============================================================


# ── Server ───────────────────────────────────────────────────

# Your domain (without https://)
DOMAIN=yourdomain.com


# ── Database ─────────────────────────────────────────────────

DB_USER=kaasb_user
DB_PASSWORD=CHANGE_ME_strong_random_password
DB_NAME=kaasb_db


# ── Security ─────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_char_hex_secret


# ── Stripe (Client Payments) ─────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...


# ── Wise (Freelancer Payouts) ─────────────────────────────────
# Get from https://wise.com/developers

WISE_API_KEY=
WISE_PROFILE_ID=
# WISE_ENVIRONMENT is forced to "production" in docker-compose.prod.yml


# ── Email (optional — for future notifications) ───────────────

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
