# =============================================================================
# Kaasb Platform — .gitattributes
# Enforces consistent line endings and marks binary files.
# =============================================================================

# Default: all text files get LF on checkout (works on all platforms)
* text=auto eol=lf

# Shell scripts — always LF (Windows Git Bash will break with CRLF)
*.sh    text eol=lf
*.bash  text eol=lf

# Python
*.py    text eol=lf
*.pyi   text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.toml  text eol=lf

# Web
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.sql   text eol=lf

# Docker
Dockerfile*  text eol=lf
*.dockerfile text eol=lf

# Env templates
*.example text eol=lf

# === Binary files — never diff or merge ===
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.mp4   binary
*.mp3   binary
*.pyc   binary
