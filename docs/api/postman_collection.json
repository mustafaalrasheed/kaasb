{
  "info": {
    "name": "Kaasb API",
    "_postman_id": "kaasb-api-v1",
    "description": "Complete API collection for the Kaasb freelancing platform.\n\n## Setup\n1. Import this collection and the `kaasb_environment.json` file.\n2. Set `base_url` in the environment (default: `http://localhost:8000/api/v1`).\n3. Run **Auth / Register** or **Auth / Login** — the token is saved automatically.\n4. All authenticated requests use `{{access_token}}` from the environment.\n\n## Authentication\nAll endpoints except `/auth/register` and `/auth/login` require a Bearer token.\nThe pre-request script on the collection root auto-refreshes expired tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "test_job_id", "value": "" },
    { "key": "test_proposal_id", "value": "" },
    { "key": "test_contract_id", "value": "" },
    { "key": "test_milestone_id", "value": "" },
    { "key": "test_conversation_id", "value": "" },
    { "key": "test_username", "value": "ali_developer" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
            "description": "Returns 200 if the application is running. Used by Docker health checks and load balancers."
          },
          "response": [
            {
              "name": "Healthy",
              "status": "OK",
              "code": 200,
              "body": "{\"status\": \"healthy\", \"db\": \"ok\", \"redis\": \"ok\"}"
            }
          ]
        },
        {
          "name": "Readiness Probe",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health/ready", "host": ["{{base_url}}"], "path": ["health", "ready"] },
            "description": "Returns 200 when the app is ready to serve traffic (DB connected, migrations applied)."
          }
        },
        {
          "name": "Detailed Diagnostics (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{health_bearer_token}}" }],
            "url": { "raw": "{{base_url}}/health/detailed", "host": ["{{base_url}}"], "path": ["health", "detailed"] },
            "description": "Full diagnostics including DB pool, Redis info, worker stats. Requires HEALTH_BEARER_TOKEN."
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const r = pm.response.json();",
                  "  pm.environment.set('access_token', r.access_token);",
                  "  pm.environment.set('refresh_token', r.refresh_token);",
                  "  pm.test('Registration successful', () => pm.expect(r.access_token).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ali.hassan@example.com\",\n  \"username\": \"ali_developer\",\n  \"password\": \"SecurePass1!\",\n  \"first_name\": \"علي\",\n  \"last_name\": \"حسن\",\n  \"primary_role\": \"freelancer\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "description": "Register a new user. Returns JWT tokens on success.\n\n**Rate limit:** 3 requests / 10 min per IP\n\n**Password rules:** min 8 chars, 1 uppercase, 1 digit, 1 special character\n\n**Roles:** `client` or `freelancer`"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const r = pm.response.json();",
                  "  pm.environment.set('access_token', r.access_token);",
                  "  pm.environment.set('refresh_token', r.refresh_token);",
                  "  pm.test('Login successful', () => pm.expect(r.token_type).to.equal('bearer'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ali.hassan@example.com\",\n  \"password\": \"SecurePass1!\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "description": "Login with email and password.\n\n**Rate limit:** 5 requests / 5 min per IP\n\n**Returns:** `access_token` (30 min) + `refresh_token` (7 days)"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const r = pm.response.json();",
                  "  pm.environment.set('access_token', r.access_token);",
                  "  pm.environment.set('refresh_token', r.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth", "refresh"] },
            "description": "Exchange a refresh token for new access + refresh tokens. Old refresh token is invalidated (rotation)."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] },
            "description": "Get the authenticated user's full profile."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] },
            "description": "Revoke the current refresh token. Access token expires naturally after 30 min."
          }
        },
        {
          "name": "Logout All Sessions",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/auth/logout-all", "host": ["{{base_url}}"], "path": ["auth", "logout-all"] },
            "description": "Revoke ALL refresh tokens for this user. Forces re-login on all devices."
          }
        }
      ]
    },
