root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space

[*.{py,pyi}]
indent_size = 4

[*.{js,jsx,ts,tsx,json,yml,yaml,css,scss,html,md}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
