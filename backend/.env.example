# Kaasb Backend — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# === App ===
ENVIRONMENT=development          # development | staging | production
DEBUG=false

# === Database ===
DATABASE_URL=postgresql+asyncpg://kaasb:kaasb@localhost:5432/kaasb_db

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Auth / JWT ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Domain (production) ===
DOMAIN=localhost

# === Qi Card (Iraqi Payment Gateway) ===
QI_CARD_API_KEY=
QI_CARD_SANDBOX=true             # false = live payments
QI_CARD_CURRENCY=IQD

# === Email (Resend) ===
RESEND_API_KEY=
EMAIL_FROM=Kaasb <noreply@kaasb.com>
EMAIL_FROM_NAME=Kaasb
FRONTEND_URL=http://localhost:3000

# === Monitoring ===
SENTRY_DSN=
LOG_LEVEL=INFO
HEALTH_BEARER_TOKEN=

# === Social Login ===
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# === SMS OTP (leave empty for email-based OTP beta) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# === File Uploads ===
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# === Platform ===
PLATFORM_FEE_PERCENT=10.0
