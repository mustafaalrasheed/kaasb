# === Kaasb Backend - Environment Variables ===
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# App
APP_NAME=Kaasb
ENVIRONMENT=development
DEBUG=true

# Database (update with your PostgreSQL credentials)
DATABASE_URL=postgresql+asyncpg://kaasb_user:YOUR_PASSWORD_HERE@localhost:5432/kaasb_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Qi Card Payment Gateway
QI_CARD_API_KEY=
QI_CARD_BASE_URL=https://api.pay.qi.iq/api/v0/transactions/business/token
QI_CARD_SANDBOX_URL=https://api.uat.pay.qi.iq/api/v0/transactions/business/token
QI_CARD_SANDBOX=true
QI_CARD_CURRENCY=IQD

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Kaasb <noreply@kaasb.com>
FRONTEND_URL=http://localhost:3000

# Domain
DOMAIN=localhost
