# === Kaasb Backend - Environment Variables ===
# Copy this file to .env and fill in your actual values.
# Generate a secure SECRET_KEY with: openssl rand -hex 32

# App
APP_NAME=Kaasb
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/kaasb_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (MUST be changed in production)
SECRET_KEY=replace-with-output-of-openssl-rand-hex-32

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
