# === Kaasb Production Environment ===
# Copy to .env.production and fill in real values
# NEVER commit .env.production to git

# Domain
DOMAIN=kaasb.com

# Database
DB_USER=kaasb_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=kaasb_db

# Auth (generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# Qi Card — Iraqi Payment Gateway
# Get credentials from: https://qi.iq (contact Qi Card merchant support)
QI_CARD_MERCHANT_ID=
QI_CARD_SECRET_KEY=
QI_CARD_BASE_URL=https://gateway.qi.iq/api/v1
QI_CARD_SANDBOX_URL=https://sandbox.gateway.qi.iq/api/v1
QI_CARD_SANDBOX=false
QI_CARD_CURRENCY=IQD
