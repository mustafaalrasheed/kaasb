# === Kaasb Production Environment ===
# Copy to .env.production and fill in real values
# NEVER commit this file to git with real values

# Domain
DOMAIN=yourdomain.com

# Database
DB_USER=kaasb_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
