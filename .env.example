# === Kaasb Platform - Docker Compose Environment ===
# Copy this file to .env and fill in your actual values.
# Generate a secure SECRET_KEY with: openssl rand -hex 32

# Database
DB_USER=kaasb_user
DB_PASSWORD=change_me
DB_NAME=kaasb_db

# Auth (MUST be changed in production — use same value as backend/.env)
SECRET_KEY=replace-with-output-of-openssl-rand-hex-32
